module stimulii();
    reg clk, rst;
    wire [3:0] ACC;
    
    four_bit_PROCESSOR dut(
        .clk(clk),
        .rst(rst),
        .ACC(ACC)
        );
    
    always #5 clk = ~clk;
    
    initial begin
        clk = 0;
        rst = 1;
        #10 rst = 0;
        
        #100 $stop;
    end
endmodule
